# Normalize to LF in the repo and in every working tree, on all platforms.
* text=auto eol=lf

# The conformance fixtures, and the reference ones they are migrated from, are byte-exact: their inputs carry CR, CRLF,
# and other bytes the test is about, and their outputs record those bytes verbatim. Never let line-ending normalization
# touch them.
tests/spec/** -text
third_party/yamlreference/tests/** -text
