# Minimal Doxygen config for the libyeast public API. Only non-default settings are listed. Keep PROJECT_NUMBER in sync
# with the CMake project version.
PROJECT_NAME          = libyeast
PROJECT_NUMBER        = $(YEAST_VERSION)
PROJECT_BRIEF         = "Grammar-derived C YAML parser"
OUTPUT_DIRECTORY      = build-docs
INPUT                 = include
FILE_PATTERNS         = *.h
EXTRACT_ALL           = NO
OPTIMIZE_OUTPUT_FOR_C = YES
GENERATE_HTML         = YES
GENERATE_MAN          = NO
GENERATE_LATEX        = NO
QUIET                 = YES

# The first sentence of every doc comment is its brief, so the compound and function indexes show a one-line
# description for each entity instead of a blank. Without this, a single-line `///` comment is a brief but a wrapped
# one is not, so half the API listed blank.
JAVADOC_AUTOBRIEF     = YES

# DoxygenLayout.xml leads with Data Structures and Functions and drops the one-entry Files tab; no sidebar tree.
GENERATE_TREEVIEW     = NO
LAYOUT_FILE           = DoxygenLayout.xml

# Every symbol shares the library prefix — ys_ on functions and types, YS_ on constants — so the alphabetical index
# buckets by the letter after it (ys_version under V, YS_CODE_BOM under C) instead of filing the whole API under Y.
IGNORE_PREFIX         = ys_ YS_

# No Graphviz dependency: skip the dot-rendered graphs (and the legend) so docs build without `dot` installed.
HAVE_DOT              = NO

# Expand the export macro to nothing so declarations parse as plain C, and keep the export-control macros themselves out
# of the API docs (implementation detail).
MACRO_EXPANSION       = YES
EXPAND_ONLY_PREDEF    = YES
PREDEFINED            = YS_API=
EXCLUDE_SYMBOLS       = YS_API YS_EXPORT YS_IMPORT

# Documentation-completeness gate: an undocumented public symbol or a missing @param fails the build (mirrors the
# coverage // UNTESTED contract).
WARN_IF_UNDOCUMENTED  = YES
WARN_IF_DOC_ERROR     = YES
WARN_NO_PARAMDOC      = YES
WARN_AS_ERROR         = FAIL_ON_WARNINGS
